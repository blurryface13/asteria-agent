# ============ LLM ============
# Any LangChain-supported provider works (openai:gpt-4o, deepseek:deepseek-chat, ...)
DEEPSEEK_API_KEY=
FAST_LLM=deepseek:deepseek-chat
SMART_LLM=deepseek:deepseek-chat
STRATEGIC_LLM=deepseek:deepseek-chat

# ============ Retrieval ============
# duckduckgo needs no API key; tavily/bing/google need their own keys
RETRIEVER=duckduckgo

# ============ Embedding ============
# Local Ollama (free, offline): `ollama pull bge-m3` then `ollama serve`
EMBEDDING=ollama:bge-m3
OLLAMA_BASE_URL=http://localhost:11434

# ============ Auth ============
# Generate a secret: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRE_MINUTES=10080
DATABASE_URL=postgresql://user@localhost:5432/bunny_research

# ============ SMTP (login code delivery) ============
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# ============ Misc ============
DOC_PATH=./my-docs

# ============ Context filtering (research pipeline) ============
# hybrid = BM25 + dense + RRF fusion + near-duplicate removal (recommended)
# dense  = original single-signal embedding threshold pipeline
CONTEXT_FILTER_MODE=hybrid
# CONTEXT_RERANK=true    # optional LLM rerank of final cut (~1.2s/sub-query)
